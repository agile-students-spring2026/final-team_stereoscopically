# Root `.env` is read automatically by Docker Compose for variable substitution
# (`docker compose up`). Do NOT commit `.env`; share values with admins only.

# Override these when using Atlas on a droplet (recommended for coursework):
#
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB_NAME=stereoscopically

JWT_SECRET=replace-with-a-long-random-secret-minimum-32-chars

# If JWT_SECRET above is omitted, Compose falls back to a dev-only placeholder in docker-compose.yml.
# Omit MONGODB_URI to use bundled MongoDB in docker-compose (good for demos / Docker extra credit).

# Optional: if port 4000 is already used by `npm run dev` in back-end, uncomment:
# HOST_API_PORT=4001
