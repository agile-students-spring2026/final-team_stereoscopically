const chai = require('chai');
const chaiHttp = require('chai-http');
const server = require('../../server');
const { expect } = chai;

chai.use(chaiHttp);

describe('Image Reframe Routes', () => {
    it('should reframe an image successfully', (done) => {
        chai.request(server)
            .post('/api/image/reframe')
            .send({ /* test data */ })
            .end((err, res) => {
                expect(res).to.have.status(200);
                expect(res.body).to.have.property('message', 'Image reframed successfully');
                done();
            });
    });

    it('should return an error for invalid input', (done) => {
        chai.request(server)
            .post('/api/image/reframe')
            .send({ /* invalid test data */ })
            .end((err, res) => {
                expect(res).to.have.status(400);
                expect(res.body).to.have.property('error');
                done();
            });
    });
});