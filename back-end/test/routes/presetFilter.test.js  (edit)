const chai = require('chai');
const chaiHttp = require('chai-http');
const server = require('../../server');
const { expect } = chai;

chai.use(chaiHttp);

describe('Preset Filter Routes', () => {
    it('should apply a preset filter correctly', (done) => {
        chai.request(server)
            .post('/api/preset-filter')
            .send({ imageId: '123', filter: 'vintage' })
            .end((err, res) => {
                expect(res).to.have.status(200);
                expect(res.body).to.have.property('success', true);
                done();
            });
    });

    it('should return an error for invalid filter', (done) => {
        chai.request(server)
            .post('/api/preset-filter')
            .send({ imageId: '123', filter: 'invalid-filter' })
            .end((err, res) => {
                expect(res).to.have.status(400);
                expect(res.body).to.have.property('error');
                done();
            });
    });
});